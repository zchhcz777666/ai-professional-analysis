# ========== 环境变量模板 ==========
# 将此文件复制为 .env.local 并填入真实值
# cp .env.example .env.local

# ========== AI 接口配置 ==========
# DeepSeek API Key
# 用于 AI 深度分析报告生成
# 申请地址：https://platform.deepseek.com/
# 支持的模型：deepseek-chat（推荐）
DEEPSEEK_API_KEY=

# ========== Vercel KV 配置 ==========
# 用于存储访问码和调用额度
# 在 Vercel 控制台创建 KV 数据库后获取
# 若未配置，系统将使用内存存储（开发环境备用）
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ========== 访问码管理 ==========
# 管理员密钥，用于生成访问码
ADMIN_SECRET=admin123

# 每个访问码的默认调用次数上限
CALLS_PER_CODE=5